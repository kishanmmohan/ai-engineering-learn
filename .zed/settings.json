{
  // Python tooling for this uv-managed project: ty (types) + ruff (lint/format).
  "languages": {
    "Python": {
      // Enable only basedpyright + ruff. Omitting pyright/ty/pylsp disables them,
      // so ruff owns lint/format and basedpyright owns type-checking (no overlap).
      "language_servers": [
        "basedpyright",
        "ruff"
      ],
      // Format on save with ruff. ruff reads [tool.ruff] from pyproject.toml
      // (line-length 88, target py314, rules E/F/I/UP/B) — single source of truth.
      "format_on_save": "on",
      "formatter": {
        "language_server": {
          "name": "ruff"
        }
      },
      // On save, organize imports and apply ruff's safe autofixes — mirrors the
      // .pre-commit-config.yaml `ruff --fix` + `ruff-format` hooks.
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
        "source.fixAll.ruff": true
      }
    }
  },
  "terminal": {
    // Auto-activate the uv virtualenv (.venv) in Zed's integrated terminal.
    "detect_venv": {
      "on": {
        "directories": [
          ".venv"
        ],
        "activate_script": "default"
      }
    },
    // Load .env.proxy (proxy master key, provider + LangFuse keys) into every new
    // terminal so `uv run ...` and curl against the proxy work without manual
    // sourcing. Zed has no env-file option, so we wrap the shell: source the file
    // (if present — it's gitignored, so may be absent) with `set -a` to export
    // every assignment, then `exec` a fresh interactive login shell that inherits
    // those vars. Secrets stay in .env.proxy, never in this committed file.
    "shell": {
      "with_arguments": {
        "program": "/bin/zsh",
        "args": [
          "-c",
          "set -a; [ -f .env.proxy ] && source .env.proxy; set +a; exec /bin/zsh -i -l"
        ]
      }
    }
  }
}
