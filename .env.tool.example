# Copy to .env.tool before starting the stack:
#   cp .env.tool.example .env.tool
#   docker compose -f docker-compose-tool.yml up -d
#
# These are injected into the containers via `env_file:` in docker-compose-tool.yml.
# (Host ports are set directly in the compose file — edit them there to remap.)

# Postgres (shared: Temporal backing store + app DB).
# NOTE: POSTGRES_USER must NOT be "temporal". Temporal's auto-setup only creates its
# `temporal` / `temporal_visibility` databases when the DB name differs from the user
# name; if they match it assumes Postgres already made them and skips creation.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

# Temporal reads the Postgres password under this name — keep it equal to POSTGRES_PASSWORD.
POSTGRES_PWD=postgres

# Neo4j credentials, format: user/password (password must be at least 8 characters).
NEO4J_AUTH=neo4j/neo4j_password
