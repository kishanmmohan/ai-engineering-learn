# Copy to .env.proxy before starting the proxy:
#   cp .env.proxy.example .env.proxy
#
# Injected into the litellm container via `env_file:` in docker-compose-proxy.yml.
# The real .env.proxy is gitignored (.env.* with a !.env.*.example exception).

# Provider keys. Two providers is deliberate — it's what makes cross-provider fallback
# (and the provider-difference lessons) real.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# LangFuse (tracing + cost attribution). Cloud defaults shown; set HOST for self-hosted.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Master key the app sends as `Authorization: Bearer <key>`. Any strong local value.
LITELLM_MASTER_KEY=sk-local-dev-change-me
